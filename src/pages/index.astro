---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const navCards = [
  { href: "/blog", title: "Blog", desc: "閱讀全部文章" },
  { href: "/category", title: "Categories", desc: "按分類瀏覽" },
  { href: "/tags", title: "Tags", desc: "按標籤查找" },
  { href: "/about", title: "About", desc: "關於我與站務說明" },
];

const externalCards = [
  {
    href: "https://t.me/truthdrift/2",
    title: "Ministry of Truth",
    desc: "真理部 · Kirishima的博客",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .section-title {
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        font-size: 1.5rem;
      }

      .card-grid {
        display: grid;
        gap: 1rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .card-grid--nav {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .card {
        margin: 0;
      }

      .card a {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        height: 100%;
        padding: 1.15rem 1.25rem;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.72);
        text-decoration: none;
        box-shadow: 0 1px 2px rgba(var(--gray), 12%);
        transition:
          border-color 0.2s ease,
          box-shadow 0.2s ease,
          transform 0.2s ease,
          background-color 0.2s ease;
      }

      .card a:hover {
        border-color: rgb(var(--accent));
        background: #fff;
        box-shadow: var(--box-shadow);
        transform: translateY(-2px);
      }

      .card a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .card__title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        color: rgb(var(--black));
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.3;
      }

      .card__desc {
        color: rgb(var(--gray));
        font-size: 0.88rem;
        font-weight: 400;
        line-height: 1.45;
      }

      .card--external .card__title::after {
        content: "↗";
        flex-shrink: 0;
        color: rgb(var(--gray));
        font-size: 0.9rem;
        font-weight: 400;
        transition: color 0.2s ease;
      }

      .card--external a:hover .card__title::after {
        color: var(--accent);
      }

      @media (max-width: 560px) {
        .card-grid--nav {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Kirishima</h1>
      <p>普通高中生，隨便整點小愛好。</p>
      <p>這裡是我的博客，用來保存閱讀、札記、碎片與未完成想法。</p>

      <h2 class="section-title">開始閱讀</h2>
      <ul class="card-grid card-grid--nav">
        {
          navCards.map((item) => (
            <li class="card">
              <a href={item.href}>
                <span class="card__title">{item.title}</span>
                <span class="card__desc">{item.desc}</span>
              </a>
            </li>
          ))
        }
      </ul>

      <h2 class="section-title">鏈接</h2>
      <ul class="card-grid">
        {
          externalCards.map((item) => (
            <li class="card card--external">
              <a href={item.href} target="_blank" rel="noopener noreferrer">
                <span class="card__title">{item.title}</span>
                <span class="card__desc">{item.desc}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>
